{
  "name": "apollo-link-scalars",
  "version": "5.0.0",
  "author": "Eduardo Turiño <eturino@eturino.com>",
  "description": "custom apollo link to allow to parse custom scalars",
  "main": "build/main/index.js",
  "typings": "build/main/index.d.ts",
  "module": "build/module/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eturino/apollo-link-scalars.git"
  },
  "homepage": "https://github.com/eturino/apollo-link-scalars",
  "bugs": "https://github.com/eturino/apollo-link-scalars/issues",
  "license": "MIT",
  "keywords": [],
  "files": [
    "build",
    "src/index.ts",
    "src/lib/*.ts",
    "src/types/dictionary.ts",
    "src/types/functions-map.ts",
    "src/types/mut-or-ro.ts",
    "src/types/null-functions.ts",
    "CHANGELOG.md"
  ],
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "scripts": {
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "describe": "npm-scripts-info",
    "build": "run-s clean && run-p build:*",
    "build:main": "tsc -p tsconfig.build.json",
    "build:module": "tsc -p tsconfig.module.json",
    "fix": "run-s fix:*",
    "fix:prettier": "prettier \"src/**/*.ts\" --write",
    "fix:eslint": "eslint \"src/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "test": "run-s test:lib test:apps",
    "test:lib": "run-s build test:eslint test:prettier test:unit check:cycles check:dead-code type-check",
    "test:eslint": "eslint \"src/**/*.ts\"",
    "test:prettier": "prettier \"src/**/*.ts\" --list-different",
    "test:unit": "vitest run --coverage",
    "test:apps": "run-s test:apps:*",
    "test:apps:type-check": "pnpm -r --filter \"./test-apps/*\" run type-check",
    "test:apps:lint": "pnpm -r --filter \"./test-apps/*\" run lint",
    "test:apps:build": "pnpm -r --filter \"./test-apps/*\" run build",
    "test:integration": "RUN_INTEGRATION=1 vitest run src/__tests__/integration",
    "test:full": "run-s test test:integration",
    "install:v3": "pnpm add --save-dev @apollo/client@^3.8.0 graphql@^16.8.0",
    "install:v4": "pnpm add --save-dev @apollo/client@^4.0.0 graphql@^16.8.0",
    "test:v3": "run-s install:v3 test:full",
    "test:v4": "run-s install:v4 test:full",
    "test:matrix": "run-s test:v3 test:v4",
    "e2e:install": "playwright install --with-deps chromium",
    "e2e": "run-s build e2e:run",
    "e2e:run": "playwright test",
    "check:cycles": "dpdm --no-tree --no-warning --exit-code circular:1 src/index.ts",
    "check:dead-code": "knip --no-config-hints",
    "cov": "run-s build cov:html && open-cli coverage/index.html",
    "cov:html": "vitest run --coverage --coverage.reporter=html",
    "watch": "run-s clean build:main && run-p \"build:main -- -w\" \"test:unit:watch\"",
    "test:unit:watch": "vitest",
    "doc": "run-s doc:html && open-cli build/docs/index.html",
    "doc:html": "typedoc --theme default src/index.ts --exclude **/*.spec.ts --out build/docs",
    "doc:json": "typedoc src/index.ts --exclude **/*.spec.ts --json build/docs/typedoc.json",
    "doc:publish": "gh-pages -m \"[ci skip] Updates\" -d build/docs",
    "version": "commit-and-tag-version",
    "reset": "git clean -dfx -e .idea && git reset --hard && pnpm install",
    "clean": "trash build test",
    "prepare-release": "run-s reset test doc:html version doc:publish"
  },
  "scripts-info": {
    "info": "Display information about the package scripts",
    "build": "Clean and rebuild the project",
    "fix": "Try to automatically fix any linting problems",
    "test": "Lint and unit test the project",
    "watch": "Watch and rebuild the project on save, then rerun relevant tests",
    "doc": "Generate HTML API documentation and open it in a browser",
    "doc:json": "Generate API documentation in typedoc JSON format",
    "version": "Bump package.json version, update CHANGELOG.md, tag release",
    "reset": "Delete all untracked files (except `.idea`) and reset the repo to the last commit",
    "prepare-release": "One-step: clean, build, test, publish docs, and prep a release"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@apollo/client": "3.x || 4.x",
    "graphql": "16.x"
  },
  "devDependencies": {
    "@apollo/client": "^4.1.9",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^10.0.1",
    "@graphql-tools/schema": "^10.0.33",
    "@playwright/test": "^1.49.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.0",
    "commit-and-tag-version": "^12.7.1",
    "cz-conventional-changelog": "^3.3.0",
    "dpdm": "^4.0.1",
    "es-toolkit": "^1.46.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "gh-pages": "^6.3.0",
    "graphql": "^16.8.0",
    "husky": "^9.1.7",
    "knip": "^6.7.0",
    "lint-staged": "^16.4.0",
    "npm-run-all": "^4.1.5",
    "open-cli": "^9.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rxjs": "^7.8.2",
    "trash-cli": "^7.2.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.0",
    "zen-observable-ts": "^1.1.0"
  },
  "packageManager": "pnpm@10.33.1",
  "volta": {
    "node": "24.15.0"
  }
}
