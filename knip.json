{
  "$schema": "https://unpkg.com/knip@5/schema.json",

  "entry": [
    "src/__tests__/**/*.spec.ts",
    "src/lib/__tests__/**/*.spec.ts"
  ],
  "project": ["src/**/*.ts"],

  "ignore": ["src/lib/__tests__/graphql-schema.fixtures.ts"],

  "ignoreDependencies": [
    "prettier-plugin-organize-imports",
    "cz-conventional-changelog"
  ],

  "ignoreBinaries": ["npm-scripts-info"],

  "tags": ["-public"],

  "rules": {
    "unresolved": "off"
  }
}
