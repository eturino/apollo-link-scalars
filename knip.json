{
  "$schema": "https://unpkg.com/knip@5/schema.json",

  "ignoreDependencies": [
    "prettier-plugin-organize-imports",
    "cz-conventional-changelog",
    "rxjs"
  ],

  "ignoreBinaries": ["npm-scripts-info"],

  "tags": ["-public"],

  "rules": {
    "unresolved": "off"
  },

  "workspaces": {
    ".": {
      "entry": [
        "src/__tests__/**/*.spec.ts",
        "src/lib/__tests__/**/*.spec.ts",
        "src/__tests__/integration/vitest.global-setup.ts",
        "playwright.config.ts"
      ],
      "project": ["src/**/*.ts"],
      "ignore": ["src/lib/__tests__/graphql-schema.fixtures.ts"]
    },
    "test-apps/graphql-test-server": {
      "entry": ["src/cli.ts", "src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "test-apps/*": {
      "entry": [
        "index.html",
        "vite.config.ts",
        "pages/**/*.tsx",
        "e2e/**/*.spec.ts"
      ],
      "project": [
        "src/**/*.{ts,tsx}",
        "pages/**/*.{ts,tsx}",
        "lib/**/*.{ts,tsx}",
        "e2e/**/*.ts"
      ]
    }
  }
}
